# ============================================================
# BLUE GUARDIAN XAUUSD SYSTEM — ENVIRONMENT CONFIG
# ============================================================

# --- LLM BACKEND (choose one) ---
LLM_BACKEND=claude          # Options: claude | ollama

# Cloud: Claude 3.5 Sonnet
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5   # claude-sonnet-4-5 (Sonnet 4.5)

# Local: Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b        # or mistral-nemo, qwen2.5:72b

# --- KNOWLEDGE GRAPH ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=blueguardian2024
NEO4J_DATABASE=xauusd

# Zep (optional memory layer — cloud or self-hosted)
ZEP_API_KEY=z_...
ZEP_BASE_URL=http://localhost:8000

# --- MARKET DATA ---
# Polygon.io (free tier: 5 API calls/min, paid: unlimited)
POLYGON_API_KEY=your_key_here

# OANDA (for XAUUSD live price feed — free practice account)
OANDA_ACCOUNT_ID=your_account_id
OANDA_API_KEY=your_api_key
OANDA_ENVIRONMENT=practice      # or live

# FRED (Federal Reserve Economic Data — free)
FRED_API_KEY=your_fred_key

# FinancialModelingPrep (DXY, yields, macro — free 250 calls/day)
FMP_API_KEY=your_fmp_key

# Alpha Vantage (backup data source — free 25 calls/day)
ALPHA_VANTAGE_API_KEY=your_key

# --- EXECUTION ---
# TradersPost (semi-automated webhook bridge → MT4/5)
TRADERSPOST_WEBHOOK_URL=https://traderspost.io/trading/webhook/...
TRADERSPOST_PASSPHRASE=your_pass

# --- EMBEDDINGS ---
EMBEDDING_BACKEND=local          # local | openai
OPENAI_API_KEY=sk-...           # only if EMBEDDING_BACKEND=openai
EMBEDDING_MODEL=nomic-embed-text # local Ollama embedding model

# --- SYSTEM ---
TIMEZONE=America/Los_Angeles
LOG_LEVEL=INFO
SIMULATION_WORKERS=8             # parallel agent threads
CONSENSUS_THRESHOLD=0.80         # 80% agreement to generate signal
MAX_DAILY_RISK_PCT=0.04          # 4% Guardian hard limit
RISK_PER_TRADE_PCT=0.01          # 1% per trade
SOFT_STOP_PCT=0.008              # Guardian Shield: 0.8% drawdown alert
ACCOUNT_BALANCE=50000            # Your challenge account size